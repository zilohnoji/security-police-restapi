{
  "PostgresSQLConnection": {
    "Url": "Server=localhost;Port=5433;Database=mg-police-db;User ID=postgres;Password=admin;"
  },
  "JwtSettings": {
    "Audience": "SecurityPoliceApp",
    "Issuer": "SecurityPoliceMG",
    "Secret": "SECURITY_POLICE_MG_GIANT_SECRET_KEY",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "EmailSettings": {
    "Subject": "Default Subject",
    "Message": "This is the default message from the API",
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "${EMAIL_USERNAME}",
    "Password": "${EMAIL_PASSWORD}",
    "Properties": {
      "SmtpAuth": true,
      "StartTlsEnable": true,
      "StartTlsRequired": true
    },
    "Ssl": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}